DJANGO_SECRET_KEY=
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DJANGO_DB_NAME=pmo_agent_dev
DJANGO_DB_USER=
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432


# フィールド暗号化鍵 (APIトークン等の暗号化保存用)
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=

# メール送信 (通知の外部連携)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true
DEFAULT_FROM_EMAIL=pmo-agent@example.com


# 本番運用時の必須設定 (F-3)
# DEBUG は本番では必ず false。SECRET_KEY 未設定だと本番は起動失敗する。
# DJANGO_DEBUG=false
# DJANGO_SECRET_KEY=  # python -c "import secrets; print(secrets.token_urlsafe(50))"
# DJANGO_ALLOWED_HOSTS=pmo.example.com
# デモデータ投入時の管理者パスワード上書き(任意)
# SEED_ADMIN_PASSWORD=
